# GyanDheesh Backend Environment Variables

# Google Gemini API Key (for summarization)
GEMINI_API_KEY=your_gemini_api_key_here

# Angel One SmartAPI Credentials (Primary Data Source)
ANGEL_API_KEY=your_angel_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_password_here
ANGEL_TOTP_KEY=your_totp_key_here

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
